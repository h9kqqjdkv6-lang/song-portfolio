# ============================================================================
# 低空经济解决方案指挥台 · 环境变量
# ============================================================================
# 复制为 .env.local（本地开发）或通过 Vercel Dashboard 设置（生产）。

# ── Supabase ─────────────────────────────────────────────────
# 在 https://supabase.com/dashboard 创建项目后获取
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── DeepSeek API ────────────────────────────────────────────
# 在 https://platform.deepseek.com/api_keys 创建
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_GENERATION_MODEL=deepseek-chat
DEEPSEEK_MONTHLY_BUDGET_CNY=10.0

# ── 高德地图（医疗应急场景用） ──────────────────────────────
AMAP_KEY=your_amap_key_here

# ── 可选：本地 AI Hub 地址 ──────────────────────────────────
# AI_HUB_URL=http://localhost:8787
